{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ENC",
  "version": "0.1.0",
  "identifier": "com.encry.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://0.0.0.0:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ENC - Encrypted File Storage",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
